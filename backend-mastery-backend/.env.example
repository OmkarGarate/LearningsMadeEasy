# ============================================
# Backend Mastery API — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

# Server
PORT=5000
NODE_ENV=development

# CORS — your Vercel frontend URL
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas — get this from your cluster "Connect" → "Drivers"
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/backend-mastery?retryWrites=true&w=majority

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_random_64_char_string
JWT_REFRESH_SECRET=replace_me_with_another_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend) — sign up at https://resend.com (free tier: 100 emails/day)
# For dev: leave blank and codes will be logged to the terminal
RESEND_API_KEY=
EMAIL_FROM=Backend Mastery <onboarding@resend.dev>

# AI Tutor (OpenAI-compatible) — sign up at:
#   OpenAI:   https://platform.openai.com/        (paid, $5 free trial)
#   Groq:     https://console.groq.com/           (free, no card needed)
#   OpenRouter: https://openrouter.ai/           (free models available)
# Leave AI_API_KEY blank to use the local pattern-based fallback.
#
# Examples:
#   OpenAI:    AI_BASE_URL=https://api.openai.com/v1       AI_MODEL=gpt-4o-mini
#   Groq:      AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
