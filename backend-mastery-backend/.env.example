# ============================================
# Backend Mastery API — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.

# Server
PORT=5000
NODE_ENV=development

# CORS — your Vercel frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# WebAuthn / Passkey
# RP_ID is your domain (without protocol). For local dev use 'localhost'.
# For production, set this to your Vercel domain (e.g. 'backend-mastery.vercel.app')
RP_ID=localhost
# The origin MUST match your frontend URL exactly (with protocol)
ORIGIN=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/backend-mastery?retryWrites=true&w=majority

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_random_64_char_string
JWT_REFRESH_SECRET=replace_me_with_another_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
